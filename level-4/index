<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <title>SIMON 造型實驗室 - LEVEL 4</title>
    <style>
        body { margin: 0; background: #080808; color: #eee; font-family: 'PingFang TC', sans-serif; overflow: hidden; }
        #ui { 
            position: absolute; top: 20px; left: 20px; background: rgba(15,15,15,0.9); 
            padding: 25px; border-radius: 12px; width: 280px; border: 1px solid #333; 
            z-index: 100; backdrop-filter: blur(10px); box-shadow: 0 10px 40px rgba(0,0,0,0.6); 
            max-height: 90vh; overflow-y: auto; /* 避免螢幕太小時超出範圍 */
        }
        /* 自訂卷軸 */
        #ui::-webkit-scrollbar { width: 6px; }
        #ui::-webkit-scrollbar-track { background: transparent; }
        #ui::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }

        .control-group { margin-bottom: 18px; }
        label { display: block; font-size: 11px; margin-bottom: 8px; color: #aaa; text-transform: uppercase; letter-spacing: 1px; }
        input[type=range] { width: 100%; cursor: pointer; }
        
        /* 客製化滑桿視覺 */
        input[type=range] { -webkit-appearance: none; background: transparent; }
        input[type=range]::-webkit-slider-runnable-track { background: #333; height: 6px; border-radius: 3px; }
        input[type=range]::-webkit-slider-thumb { 
            -webkit-appearance: none; background: #00ffcc; width: 16px; height: 16px; 
            border-radius: 50%; margin-top: -5px; box-shadow: 0 0 10px rgba(0,255,204,0.6); 
            transition: transform 0.1s;
        }
        input[type=range]::-webkit-slider-thumb:hover { transform: scale(1.2); }
        
        /* 比例滑桿使用不同顏色以作區別 */
        .prop-slider::-webkit-slider-thumb { background: #ffaa00 !important; box-shadow: 0 0 10px rgba(255,170,0,0.6) !important; }
        
        .value { float: right; color: #00ffcc; font-weight: bold; font-family: monospace; font-size: 14px; }
        .prop-val { color: #ffaa00; }

        h3 { margin: 0 0 5px 0; font-size: 18px; letter-spacing: 1px; color: #fff; }
        .desc { font-size: 12px; color: #666; margin-bottom: 20px; font-weight: 300; }
        .hint { font-size: 12px; line-height: 1.8; color: #999; border-top: 1px solid #333; padding-top: 20px; margin-top: 15px; }
        .hint b { color: #fff; }
        .back-btn { display: flex; align-items: center; gap: 8px; text-decoration: none; color: #00ffcc; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 20px; padding: 10px 14px; border: 1px solid rgba(0,255,204,0.3); border-radius: 8px; background: rgba(0,255,204,0.06); transition: background 0.2s, border-color 0.2s; }
        .back-btn:hover { background: rgba(0,255,204,0.14); border-color: rgba(0,255,204,0.7); }
        .back-btn span { font-size: 14px; }
        .divider { height: 1px; background: #333; margin: 20px 0; }
    </style>
</head>
<body>

<div id="ui">
    <a href="../index.html" class="back-btn"><span>←</span> 返回課程首頁</a>
    <h3>SIMON Form Lab</h3>
    <div class="desc">LEVEL 4：長寬高比例與造型張力</div>

    <div class="control-group">
        <label>寬度 (Width - X) <span id="wVal" class="value prop-val">120</span></label>
        <input type="range" class="prop-slider" id="width" min="20" max="250" step="1" value="120">
    </div>

    <div class="control-group">
        <label>高度 (Height - Y) <span id="hVal" class="value prop-val">40</span></label>
        <input type="range" class="prop-slider" id="height" min="10" max="250" step="1" value="40">
    </div>

    <div class="control-group">
        <label>深度 (Depth - Z) <span id="dVal" class="value prop-val">180</span></label>
        <input type="range" class="prop-slider" id="depth" min="20" max="250" step="1" value="180">
    </div>

    <div class="divider"></div>

    <div class="control-group">
        <label>頂部 R 角 (Top Radius) <span id="tRVal" class="value">10</span></label>
        <input type="range" id="topR" min="0" max="50" step="0.5" value="10">
    </div>

    <div class="control-group">
        <label>底部 R 角 (Bottom Radius) <span id="bRVal" class="value">2</span></label>
        <input type="range" id="botR" min="0" max="50" step="0.5" value="2">
    </div>

    <div class="control-group">
        <label>垂直邊 R 角 (Side Radius) <span id="sRVal" class="value">15</span></label>
        <input type="range" id="sideR" min="0" max="50" step="0.5" value="15">
    </div>

    <div class="hint">
        <b>教學觀察重點：</b><br>
        1. <b>量體感差異：</b>將比例拉成細長的遙控器或扁平的電視盒，觀察相同的 R 角數值在不同體積下的視覺佔比。<br>
        2. <b>曲面張力：</b>當長寬差異極大時，Side R 會影響立面的俐落度；試著在扁平物件上加強 Top R，感受曲面的飽滿度。<br>
        3. <b>極限防護：</b>演算法已設定防呆，當厚度(Y)小於 R 角時，R 角會自動適應最大極限，觀察這種「逼近極限」的收口變化。
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/utils/BufferGeometryUtils.js"></script>

<script>
    let scene, camera, renderer, mesh, controls;

    const material = new THREE.MeshPhysicalMaterial({
        color: 0xdcdcdc,
        metalness: 0.3,
        roughness: 0.15,
        clearcoat: 0.8,         
        clearcoatRoughness: 0.1,
        flatShading: false
    });

    init();
    animate();

    function init() {
        scene = new THREE.Scene();
        scene.background = new THREE.Color(0x0a0a0a);

        camera = new THREE.PerspectiveCamera(35, window.innerWidth / window.innerHeight, 1, 1000);
        camera.position.set(250, 200, 250);

        renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2)); 
        document.body.appendChild(renderer.domElement);

        controls = new THREE.OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.dampingFactor = 0.05;

        // 打光設定保持不變，強化曲面高光
        scene.add(new THREE.AmbientLight(0x2a2a2a));

        const mainLight = new THREE.DirectionalLight(0xffffff, 1.2);
        mainLight.position.set(100, 200, 150);
        scene.add(mainLight);

        const fillLight = new THREE.DirectionalLight(0x00ffcc, 0.6);
        fillLight.position.set(-100, -50, 100);
        scene.add(fillLight);

        const rimLight = new THREE.DirectionalLight(0xff00cc, 0.3); 
        rimLight.position.set(100, -100, -200);
        scene.add(rimLight);

        updateMesh();

        // 綁定 6 個滑桿的 UI 事件
        const inputs = ['width', 'height', 'depth', 'topR', 'botR', 'sideR'];
        inputs.forEach(id => {
            document.getElementById(id).addEventListener('input', updateUI);
        });

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    }

    function updateUI() {
        document.getElementById('wVal').innerText = document.getElementById('width').value;
        document.getElementById('hVal').innerText = document.getElementById('height').value;
        document.getElementById('dVal').innerText = document.getElementById('depth').value;
        document.getElementById('tRVal').innerText = document.getElementById('topR').value;
        document.getElementById('bRVal').innerText = document.getElementById('botR').value;
        document.getElementById('sRVal').innerText = document.getElementById('sideR').value;
        updateMesh();
    }

    function updateMesh() {
        if (mesh) {
            scene.remove(mesh);
            mesh.geometry.dispose();
        }

        const w = parseFloat(document.getElementById('width').value);
        const h = parseFloat(document.getElementById('height').value);
        const d = parseFloat(document.getElementById('depth').value);
        
        const topR = parseFloat(document.getElementById('topR').value);
        const botR = parseFloat(document.getElementById('botR').value);
        const sideR = parseFloat(document.getElementById('sideR').value);

        const geometry = createVariableRoundedBox(w, h, d, topR, botR, sideR);
        mesh = new THREE.Mesh(geometry, material);
        scene.add(mesh);
    }

    // 升級版演算法：支援獨立長寬高，並動態限制 R 角極限
    function createVariableRoundedBox(w, h, d, topR, botR, sideR) {
        // 為了在極度細長的比例下依然保持網格平滑，將基礎分段數維持在 48，
        // 實務上若有效能考量，可依比例 (w, h, d) 動態給予不同的 segX, segY, segZ。
        const seg = 48; 
        let geometry = new THREE.BoxGeometry(w, h, d, seg, seg, seg);
        const pos = geometry.attributes.position;
        
        // 取得各軸向的半徑限制
        let hx = w / 2;
        let hy = h / 2;
        let hz = d / 2;

        // 【關鍵邏輯升級】：R 角的極限值必須受到該軸向尺寸的限制
        // Side R (垂直邊) 會受限於 X 寬度與 Z 深度
        const safeSideR = Math.max(0, Math.min(sideR, hx, hz));
        // Top / Bot R (上下緣) 會受限於 Y 高度，同時也不能超過 X 與 Z，否則球化會變形
        const safeTopR = Math.max(0, Math.min(topR, hx, hy, hz));
        const safeBotR = Math.max(0, Math.min(botR, hx, hy, hz));

        for (let i = 0; i < pos.count; i++) {
            let x = pos.getX(i);
            let y = pos.getY(i);
            let z = pos.getZ(i);

            let signX = Math.sign(x) || 1;
            let signY = Math.sign(y) || 1;
            let signZ = Math.sign(z) || 1;

            let ax = Math.abs(x);
            let ay = Math.abs(y);
            let az = Math.abs(z);

            let rY = y > 0 ? safeTopR : safeBotR;
            let rX = safeSideR;
            let rZ = safeSideR;

            // 定義未倒角前「內部直角方塊」的邊界
            let cx = hx - rX;
            let cy = hy - rY;
            let cz = hz - rZ;

            let dx = Math.max(0, ax - cx);
            let dy = Math.max(0, ay - cy);
            let dz = Math.max(0, az - cz);

            let nx = rX <= 0 ? 0 : dx / rX;
            let ny = rY <= 0 ? 0 : dy / rY;
            let nz = rZ <= 0 ? 0 : dz / rZ;

            // 球面映射演算法 (不變，因為它是基於歸一化比例運算)
            let mapX = nx * Math.sqrt(Math.max(0, 1 - (ny*ny)/2 - (nz*nz)/2 + (ny*ny*nz*nz)/3));
            let mapY = ny * Math.sqrt(Math.max(0, 1 - (nx*nx)/2 - (nz*nz)/2 + (nx*nx*nz*nz)/3));
            let mapZ = nz * Math.sqrt(Math.max(0, 1 - (nx*nx)/2 - (ny*ny)/2 + (nx*nx*ny*ny)/3));

            // 推算回真實的三維坐標
            let finalX = Math.min(ax, cx) + mapX * rX;
            let finalY = Math.min(ay, cy) + mapY * rY;
            let finalZ = Math.min(az, cz) + mapZ * rZ;

            pos.setXYZ(i, finalX * signX, finalY * signY, finalZ * signZ);
        }

        pos.needsUpdate = true;
        
        geometry = THREE.BufferGeometryUtils.mergeVertices(geometry);
        geometry.computeVertexNormals();

        return geometry;
    }

    function animate() {
        requestAnimationFrame(animate);
        controls.update();
        renderer.render(scene, camera);
    }
</script>
</body>
</html>
